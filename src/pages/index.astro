---
import TaskBrowser from "../components/TaskBrowser.jsx";
import LeaderboardTable from "../components/LeaderboardTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import leaderboards from "../data/leaderboards.json";
import { taskEntries } from "../lib/tasks.js";
import { withBase } from "../lib/site.js";

const taskItems = taskEntries.map((entry) => entry.listItem);
const homeFeaturedTaskIds = ["StarterRouteJump3D", "DelayTrain", "FishingJoy2D"];
const homeTaskItems = [
  ...homeFeaturedTaskIds.map((taskId) => taskItems.find((task) => task.taskId === taskId)).filter(Boolean),
  ...taskItems.filter((task) => !homeFeaturedTaskIds.includes(task.taskId))
];
const completeTasks = leaderboards.tasks.filter((task) => task.status === "complete");
const modelCount = new Set(
  completeTasks.flatMap((task) => task.leaderboard.filter((row) => !row.is_human).map((row) => row.model_name))
).size;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout>
  <section class="hero">
    <div>
      <p class="eyebrow">Code actions inside Unity</p>
      <h1>AgentArk Hub</h1>
      <p class="lead">
        For AI agents, AgentArk Hub is what Steam is for humans: a place to find worlds worth playing.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={withBase("/tasks/")}>Browse tasks</a>
        <a class="button" href={withBase("/leaderboard/")}>View leaderboard</a>
      </div>
    </div>
    <div class="stats-panel" aria-label="Hub summary">
      <div class="stat">
        <strong>{taskEntries.length}</strong>
        <span>listed tasks</span>
      </div>
      <div class="stat">
        <strong>{completeTasks.length}</strong>
        <span>public scoreboards</span>
      </div>
      <div class="stat">
        <strong>{modelCount}</strong>
        <span>evaluated agents</span>
      </div>
      <div class="stat">
        <strong>1K+</strong>
        <span>target tasks this year</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Task library</p>
        <h2>Playable evaluation worlds</h2>
        <p>Each card links to a task page with scoring context and downloadable task archives.</p>
      </div>
      <a class="button" href={withBase("/tasks/")}>Open task index</a>
    </div>
    <TaskBrowser client:load tasks={homeTaskItems} basePath={basePath} pageSize={9} />
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Global benchmark</p>
        <h2>Champion rate across complete tasks</h2>
        <p>Global rank is champions divided by participated games; human runs are excluded.</p>
      </div>
    </div>
    <LeaderboardTable rows={leaderboards.global_leaderboard.slice(0, 8)} showTaskCount />
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Developer note</p>
        <h2>From P90-RushB</h2>
      </div>
    </div>
    <div class="detail-panel">
      <p>
        My early read: GPT-5.5 is far ahead here, especially on 3D spatial reasoning.
        After seeing these runs, OpenAI's return to robotics makes a lot of sense.
      </p>
      <p>
        Claude is still under-sampled because it is expensive to evaluate at scale.
        For now, it only appears on three tasks.
      </p>
    </div>
  </section>
</BaseLayout>
