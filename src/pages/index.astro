---
import TaskBrowser from "../components/TaskBrowser.jsx";
import LeaderboardTable from "../components/LeaderboardTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import leaderboards from "../data/leaderboards.json";
import { taskEntries } from "../lib/tasks.js";
import { withBase } from "../lib/site.js";

const taskItems = taskEntries.map((entry) => entry.listItem);
const completeTasks = leaderboards.tasks.filter((task) => task.status === "complete");
const modelCount = new Set(
  completeTasks.flatMap((task) => task.leaderboard.map((row) => row.model_name))
).size;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout>
  <section class="hero">
    <div>
      <p class="eyebrow">Code actions inside Unity</p>
      <h1>AgentArk Hub</h1>
      <p class="lead">
        A Steam-like catalog for AgentArk tasks: downloadable mods, task writeups, videos,
        and public scoreboards for multimodal agents that act by producing executable code.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={withBase("/tasks/")}>Browse tasks</a>
        <a class="button" href={withBase("/leaderboard/")}>View leaderboard</a>
      </div>
    </div>
    <div class="stats-panel" aria-label="Hub summary">
      <div class="stat">
        <strong>{taskEntries.length}</strong>
        <span>listed tasks</span>
      </div>
      <div class="stat">
        <strong>{completeTasks.length}</strong>
        <span>public scoreboards</span>
      </div>
      <div class="stat">
        <strong>{modelCount}</strong>
        <span>evaluated agents</span>
      </div>
      <div class="stat">
        <strong>{leaderboards.skipped_tasks.length}</strong>
        <span>pending imports</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Task library</p>
        <h2>Playable evaluation worlds</h2>
        <p>Each card links to a task page with scoring context and asset placeholders.</p>
      </div>
      <a class="button" href={withBase("/tasks/")}>Open task index</a>
    </div>
    <TaskBrowser client:load tasks={taskItems.slice(0, 6)} basePath={basePath} />
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Global benchmark</p>
        <h2>Model coverage across complete tasks</h2>
        <p>Only aggregate scores are published; raw trajectories stay outside the hub.</p>
      </div>
    </div>
    <LeaderboardTable rows={leaderboards.global_leaderboard.slice(0, 6)} showTaskCount />
  </section>
</BaseLayout>
