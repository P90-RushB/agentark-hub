---
import LeaderboardTable from "../components/LeaderboardTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import leaderboards from "../data/leaderboards.json";
---

<BaseLayout title="Leaderboard">
  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Cross-task results</p>
        <h1>Global leaderboard</h1>
        <p>
          Global rank uses champion count divided by participated games, excluding human
          runs so tasks with different reward scales can still be compared fairly.
        </p>
      </div>
    </div>
    <LeaderboardTable rows={leaderboards.global_leaderboard} showTaskCount />
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Import notes</p>
        <h2>Skipped or pending tasks</h2>
      </div>
    </div>
    <div class="detail-panel">
      {
        leaderboards.skipped_tasks.length === 0 ? (
          <p class="muted">No skipped tasks in the latest import.</p>
        ) : (
          <ul>
            {leaderboards.skipped_tasks.map((task) => (
              <li>
                <strong>{task.task_id}</strong>: {task.reason}
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>
