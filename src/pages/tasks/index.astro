---
import TaskBrowser from "../../components/TaskBrowser.jsx";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { taskEntries } from "../../lib/tasks.js";

const taskItems = taskEntries.map((entry) => entry.listItem);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="Tasks">
  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Task index</p>
        <h1>AgentArk tasks</h1>
        <p>
          Browse the public AgentArk task catalog with aggregate scoreboards, task notes,
          and visual covers generated from local environment runs.
        </p>
      </div>
    </div>
    <TaskBrowser client:load tasks={taskItems} basePath={basePath} pageSize={12} />
  </section>
</BaseLayout>
