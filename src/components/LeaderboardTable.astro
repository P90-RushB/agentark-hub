---
import { formatModelName, formatPercent, formatScore } from "../lib/site.js";

const { rows = [], showTaskCount = false } = Astro.props;
---

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Rank</th>
        <th>Model</th>
        <th>Provider</th>
        {showTaskCount ? (
          <>
            <th>Champions</th>
            <th>Games</th>
            <th>Champion rate</th>
            <th>Avg success</th>
          </>
        ) : (
          <>
            <th>Mean score</th>
            <th>Success rate</th>
            <th>Seeds</th>
          </>
        )}
      </tr>
    </thead>
    <tbody>
      {
        rows.length === 0 ? (
          <tr>
            <td colspan={showTaskCount ? 7 : 6} class="muted">No complete public leaderboard yet.</td>
          </tr>
        ) : (
          rows.map((row, index) => (
            <tr>
              <td>{index + 1}</td>
              <td>
                <strong>{formatModelName(row.model_name)}</strong>
                {row.model && row.model !== row.model_name ? <div class="muted">{formatModelName(row.model)}</div> : null}
              </td>
              <td>{row.provider}</td>
              {showTaskCount ? (
                <>
                  <td class="score">{row.champion_count ?? 0}</td>
                  <td>{row.task_count}</td>
                  <td class="score">{formatPercent(row.champion_rate)}</td>
                  <td>{formatPercent(row.success_rate)}</td>
                </>
              ) : (
                <>
                  <td class="score">{formatScore(row.score_mean)}</td>
                  <td>{formatPercent(row.success_rate)}</td>
                  <td>{row.seed_count}</td>
                </>
              )}
            </tr>
          ))
        )
      }
    </tbody>
  </table>
</div>
